{
  "bugs": {
    "url": "https://github.com/bastianparedes/ba-tester/issues"
  },
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@vitest/coverage-v8": "^4.0.18",
    "vitest": "^4.0.18"
  },
  "homepage": "https://github.com/bastianparedes/ba-tester#readme",
  "name": "ba-tester",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastianparedes/ba-tester.git"
  },
  "scripts": {
    "build:backend": "cd apps/backend && npm run build",
    "build:frontend": "cd apps/frontend && npm run build",
    "dev": "docker compose up",
    "dev:lazy": "docker compose up -d && lazydocker",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "version": "1.0.0"
}
